CO2
data(co2)
head(CO2)
class(CO2)
data.frame
co2
help("co2")
class(CO2)
class(co2)
plot(co2,main='Atmospherics CO2 Concentration')
co2.values
co2.values = as.numeric(co2)
co2.times = as.numeric(time(co2))
ssxx = (co2.times-mean(co2.times))**2
ssxx = sum((co2.times-mean(co2.times))**2)
ssxx = sum((co2.times-mean(co2.times))*(co2.times-mean(co2.times)))
ssxy = sum((co2.times-mean(co2.times))*(co2.values-mean(co2.values)))
slope=ssxy/ssxx
intercept=mean(co2.values)-slope*mean(co2.times)
co2.linear.model = lm(co2)
co2.linear.model = lm(co2-time(co2))
co2.linear.model = lm(co2~time(co2))
abline(co2.linear.model)
